#include <stdio.h>

int main()
{
    int arr[100], n, flag = 0;

    printf("Enter number of elements: ");
    scanf("%d",&n);

    printf("Enter elements:\n");
    for(int i=0;i<n;i++)
        scanf("%d",&arr[i]);

    for(int i=0;i<n;i++)
    {
        for(int j=i+1;j<n;j++)
        {
            if(arr[i] == arr[j])
            {
                flag = 1;
                break;
            }
        }
        if(flag) break;
    }

    if(flag)
        printf("Duplicates found\n");
    else
        printf("No duplicates found\n");

    return 0;
}
