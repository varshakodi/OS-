#include <stdio.h>

int main()
{
    int arr[100], n, min, pos;

    printf("Enter number of elements: ");
    scanf("%d",&n);

    printf("Enter elements:\n");
    for(int i=0;i<n;i++)
        scanf("%d",&arr[i]);

    min = arr[0];
    pos = 0;

    for(int i=1;i<n;i++)
    {
        if(arr[i] < min)
        {
            min = arr[i];
            pos = i;
        }
    }

    printf("Smallest element = %d\n", min);
    printf("Position = %d\n", pos+1);

    return 0;
}
